SQLITE_PATH=./data/career_compass.db

# SearXNG endpoint.
#   - Local dev (host machine, no docker): http://localhost:8888
#   - Inside docker compose: docker-compose.yml overrides this with
#     http://searxng:8080 (the in-network service:port). Do not change
#     it here for docker; change the compose `environment:` instead.
SEARXNG_URL=http://localhost:8888

CORS_ORIGINS=["http://localhost:5173"]
MAX_UPLOAD_SIZE=5242880
SEARXNG_TIMEOUT=10
SEARXNG_MAX_RESULTS=20
SEARXNG_CACHE_TTL=300
LOG_LEVEL=INFO
TASK_EXPIRY=3600
SPACY_MODEL=en_core_web_sm
